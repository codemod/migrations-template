{
  "name": "<SCOPE>-codemods",
  "version": "0.1.0",
  "private": true,
  "description": "Codemods for <SCOPE>",
  "type": "module",
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --type-check --deny-warnings .",
    "lint:fix": "oxlint --type-aware --type-check --fix .",
    "test": "pnpm --filter \"./codemods/*\" test",
    "check-types": "tsc --noEmit",
    "ci": "pnpm run test && pnpm run check-types",
    "docs:links": "markdown-link-check README.md CONTRIBUTING.md docs/CODEMOD-TEMPLATE.md",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@codemod.com/jssg-types": "catalog:",
    "@types/node": "catalog:",
    "codemod": "^1.12.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "markdown-link-check": "^3.13.6",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.19.0"
}
